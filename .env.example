# Copy this file to .env. Never store real secrets in .env.example.
APP_ENV=development
LLM_PROVIDER=mock
LLM_TIMEOUT_SECONDS=60
WEB_ORIGIN=http://localhost:3000

# Frontend (copy this value to apps/web/.env.local).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Required only when LLM_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Required only when LLM_PROVIDER=dashscope.
DASHSCOPE_API_KEY=your-api-key
DASHSCOPE_WORKSPACE_ID=your-workspace-id
DASHSCOPE_MODEL=qwen-plus

# Optional compatibility override when no workspace ID is configured.
# DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Required only when LLM_PROVIDER=local. API key may be empty.
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_API_KEY=
LOCAL_LLM_MODEL=llama3.1

# Hot-topic feed (mock | hackernews). hackernews is a free keyless API.
TREND_SOURCE=mock

# Visual generation/understanding (mock | dashscope | zimage).
# dashscope reuses DASHSCOPE_API_KEY: Qwen-Image for generation, Qwen3-VL for critique.
# zimage points at a self-hosted Z-Image-Turbo server (on-prem, 16GB VRAM).
MEDIA_PROVIDER=mock
VISION_PROVIDER=mock
DASHSCOPE_IMAGE_MODEL=qwen-image
DASHSCOPE_VL_MODEL=qwen3-vl-plus
# ZIMAGE_BASE_URL=http://localhost:9800/v1
