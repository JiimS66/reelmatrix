# Copy to .env on the deploy server: `cp .env.deploy.example .env`, then fill the values.
# Never commit the real .env. docker-compose interpolates ${PUBLIC_IP} from this file,
# and deploy.sh reads PUBLIC_IP from it to print the app URL.

# --- Required ---------------------------------------------------------------

# The server's public IP (or domain). Baked into the frontend as the API base URL
# and used for backend CORS — must match the address you open in the browser.
PUBLIC_IP=

# Which model powers the copilot in production.
LLM_PROVIDER=dashscope

# DashScope (Qwen) — required when LLM_PROVIDER=dashscope.
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus
# Only if your account uses a workspace:
# DASHSCOPE_WORKSPACE_ID=
# Optional endpoint override (e.g. the intl endpoint):
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- Recommended: the Bailian one-platform setup ----------------------------
# One Bailian (DashScope) key covers BOTH model families: Qwen writes, DeepSeek
# judges. The auditor rides the "siliconflow" provider slot pointed at Bailian's
# OpenAI-compatible endpoint — the seed auto-pins the Content auditor to it
# whenever SILICONFLOW_API_KEY is set (no Team-tab step after a reseed).
# Verify the exact model ids your account sees:
#   curl -s -H "Authorization: Bearer $KEY" \
#     https://dashscope.aliyuncs.com/compatible-mode/v1/models | grep deepseek
# SILICONFLOW_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# SILICONFLOW_API_KEY=<the same Bailian key>
# SILICONFLOW_MODEL=deepseek-v4-flash

# Parallel drafts per post — render N candidates, keep the best. Cheap with
# open-weight pricing; 3 is a good live default (1 = off, the mock default).
# ASSET_DRAFT_FANOUT=3

# Fire-and-forget review-queue pings (Feishu/DingTalk/Slack incoming webhook).
# NOTIFY_WEBHOOK_URL=

# Hot-topic feed. NOTE: news.ycombinator.com is often unreachable from
# mainland-China servers — the source degrades to an empty list, but "mock"
# keeps the demo lively there.
# TREND_SOURCE=mock

# --- Optional ---------------------------------------------------------------

# Per-request LLM timeout.
LLM_TIMEOUT_SECONDS=60

# OpenAI — only when LLM_PROVIDER=openai.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Any OpenAI-compatible local runtime — only when LLM_PROVIDER=local.
# LOCAL_LLM_BASE_URL=http://localhost:11434/v1
# LOCAL_LLM_API_KEY=
# LOCAL_LLM_MODEL=qwen2.5

# Deploy marker override. Normally deploy.sh stamps the VERSION file from git;
# set this only for tar-archive deploys without a stamped VERSION.
# COMMIT_SHA=

# Notes: APP_ENV, DATABASE_URL and WEB_ORIGIN are set by docker-compose.yml —
# do not set them here.
